<?xml version="1.0" encoding="utf-8"?>
<!-- AKTİF durum için neon cyan/yeşil glow halkası — layer-list ile iç içe daireler -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- En dış glow katmanı (en soluk, en büyük) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1200FF88" />
        </shape>
    </item>

    <!-- Dış glow halkası -->
    <item
        android:top="6dp"
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp">
        <shape android:shape="oval">
            <solid android:color="#2000E5FF" />
        </shape>
    </item>

    <!-- Cyan parlak halka (ince çizgi) -->
    <item
        android:top="12dp"
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp">
        <shape android:shape="oval">
            <solid android:color="#FF00E5FF" />
        </shape>
    </item>

    <!-- Yeşil iç kenarlık -->
    <item
        android:top="14dp"
        android:bottom="14dp"
        android:left="14dp"
        android:right="14dp">
        <shape android:shape="oval">
            <solid android:color="#FF00FF66" />
        </shape>
    </item>

    <!-- İç koyu daire (arka plan) -->
    <item
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp">
        <shape android:shape="oval">
            <solid android:color="#E6060C18" />
        </shape>
    </item>

</layer-list>
