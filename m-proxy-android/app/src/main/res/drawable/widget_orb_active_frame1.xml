<?xml version="1.0" encoding="utf-8"?>
<!-- Active VPN Orb Wave Animation - Frame 1 (Smallest) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer green glow (small) -->
    <item
        android:top="12dp"
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp">
        <shape android:shape="oval">
            <solid android:color="#1500FF88" />
        </shape>
    </item>

    <!-- Outer cyan glow (small) -->
    <item
        android:top="14dp"
        android:bottom="14dp"
        android:left="14dp"
        android:right="14dp">
        <shape android:shape="oval">
            <solid android:color="#2500E5FF" />
        </shape>
    </item>

    <!-- Bright active ring -->
    <item
        android:top="16dp"
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp">
        <shape android:shape="oval">
            <solid android:color="#FF00E5FF" />
        </shape>
    </item>

    <!-- Inner green ring -->
    <item
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp">
        <shape android:shape="oval">
            <solid android:color="#FF00FF66" />
        </shape>
    </item>

    <!-- Inner dark core -->
    <item
        android:top="22dp"
        android:bottom="22dp"
        android:left="22dp"
        android:right="22dp">
        <shape android:shape="oval">
            <solid android:color="#E6060C18" />
        </shape>
    </item>

</layer-list>
